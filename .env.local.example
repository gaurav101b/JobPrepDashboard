# Copy this file to .env.local and fill in real values, then restart `npm run dev`.

# Spotify Now Playing widget (optional)
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Add http://localhost:3000/api/spotify/callback as a Redirect URI
# 3. Paste the Client ID + Client Secret below
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback
