# Copy this file to .env.local and fill in real values, then restart `npm run dev`.

# Spotify Now Playing widget (optional)
#
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Add this exact Redirect URI on the dashboard:
#       http://127.0.0.1:3000/api/spotify/callback
#    (Spotify rejects "localhost" since April 2025; use 127.0.0.1 instead.)
# 3. Open the dashboard with `http://127.0.0.1:3000` in your browser
#    (not http://localhost:3000) so the OAuth redirect matches.
# 4. Paste the Client ID + Client Secret below and restart `npm run dev`.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback
